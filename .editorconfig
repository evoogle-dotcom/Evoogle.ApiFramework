# Root editorconfig
root = true

# Exclude generated directories
[bin/**]
generated_code = true

[obj/**]
generated_code = true

# =========================================================
# Core formatting
# =========================================================

[*]
# Use UTF-8 encoding with BOM (Byte Order Mark)
charset = utf-8-bom

# Use CRLF (Windows-style) line endings
end_of_line = crlf

# Indentation and spacing
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 100
tab_width = 4
trim_trailing_whitespace = true

# Using directives: outside namespace; System first
csharp_using_directive_placement = outside_namespace:error
dotnet_sort_system_directives_first = true

# Namespace declarations: file-scoped
csharp_style_namespace_declarations = file_scoped:error

# Newline/brace rules
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_prefer_braces = true:error

# Braces should always be on their own line, even if the block is empty
csharp_style_allow_embedded_statements_on_same_line = false

# Allow blank lines between consecutive braces for clarity
csharp_style_allow_blank_lines_between_consecutive_braces = true

# Spacing
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_after_comma = true
csharp_space_between_parentheses = false
csharp_space_around_binary_operators = before_and_after

# var usage
csharp_style_var_when_type_is_apparent = true:error
csharp_style_var_for_built_in_types = true:error
csharp_style_var_elsewhere = true:error

# Expression-bodied members
csharp_style_expression_bodied_properties = when_possible:error
csharp_style_expression_bodied_methods = never:error

# Prefer readonly/const where applicable
dotnet_style_readonly_field = true:error
csharp_style_prefer_readonly_struct = true:error
csharp_style_prefer_static_local_function = true:error

# Modifier order
csharp_preferred_modifier_order = public,protected,internal,private,new,abstract,virtual,override,sealed,static,readonly,extern,unsafe,volatile,async:error
dotnet_style_require_accessibility_modifiers = for_non_interface_members:error

# Pattern preferences
csharp_style_deconstructed_variable_declaration = true:error
csharp_style_pattern_local_over_anonymous_function = true:error
csharp_style_prefer_switch_expression = true:error

# =========================================================
# Naming conventions
# =========================================================

# ---------- Styles ----------
dotnet_naming_style.pascal_case.capitalization = pascal_case
dotnet_naming_style.pascal_case.required_prefix =
dotnet_naming_style.camel_case.capitalization = camel_case
dotnet_naming_style.camel_case.required_prefix =
dotnet_naming_style.underscore_camel.capitalization = camel_case
dotnet_naming_style.underscore_camel.required_prefix = _
dotnet_naming_style.interface_pascal_with_i.capitalization = pascal_case
dotnet_naming_style.interface_pascal_with_i.required_prefix = I

dotnet_style_qualification_for_field = false
dotnet_style_qualification_for_property = true:error
dotnet_style_qualification_for_method = true:error
dotnet_style_qualification_for_event = true:error

# ---------- Symbols ----------
dotnet_naming_symbols.public_api.applicable_kinds = namespace,class,struct,enum,delegate,interface,property,method,field,event
dotnet_naming_symbols.public_api.applicable_accessibilities = public
dotnet_naming_symbols.public_api.required_modifiers =

dotnet_naming_symbols.nonpublic_instance_fields.applicable_kinds = field
dotnet_naming_symbols.nonpublic_instance_fields.applicable_accessibilities = private,protected,internal,protected_internal
dotnet_naming_symbols.nonpublic_instance_fields.required_modifiers =

dotnet_naming_symbols.nonpublic_properties.applicable_kinds = property
dotnet_naming_symbols.nonpublic_properties.applicable_accessibilities = private,protected,internal,protected_internal
dotnet_naming_symbols.nonpublic_properties.required_modifiers =

dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = *
dotnet_naming_symbols.interfaces.required_modifiers =

dotnet_naming_symbols.enums.applicable_kinds = enum
dotnet_naming_symbols.enums.applicable_accessibilities = *
dotnet_naming_symbols.enums.required_modifiers =

dotnet_naming_symbols.enum_members.applicable_kinds = enum_member
dotnet_naming_symbols.enum_members.applicable_accessibilities = *
dotnet_naming_symbols.enum_members.required_modifiers =

dotnet_naming_symbols.locals.applicable_kinds = local
dotnet_naming_symbols.locals.applicable_accessibilities = *
dotnet_naming_symbols.locals.required_modifiers =

dotnet_naming_symbols.parameters.applicable_kinds = parameter
dotnet_naming_symbols.parameters.applicable_accessibilities = *
dotnet_naming_symbols.parameters.required_modifiers =

# ---------- Rules ----------
dotnet_naming_rule.public_api_pascal.symbols = public_api
dotnet_naming_rule.public_api_pascal.style = pascal_case
dotnet_naming_rule.public_api_pascal.severity = error

dotnet_naming_rule.interfaces_ipascal.symbols = interfaces
dotnet_naming_rule.interfaces_ipascal.style = interface_pascal_with_i
dotnet_naming_rule.interfaces_ipascal.severity = error

dotnet_naming_rule.enums_pascal.symbols = enums
dotnet_naming_rule.enums_pascal.style = pascal_case
dotnet_naming_rule.enums_pascal.severity = error

dotnet_naming_rule.enum_members_pascal.symbols = enum_members
dotnet_naming_rule.enum_members_pascal.style = pascal_case
dotnet_naming_rule.enum_members_pascal.severity = error

dotnet_naming_rule.nonpublic_fields_underscore_camel.symbols = nonpublic_instance_fields
dotnet_naming_rule.nonpublic_fields_underscore_camel.style = underscore_camel
dotnet_naming_rule.nonpublic_fields_underscore_camel.severity = error

dotnet_naming_rule.nonpublic_properties_pascal.symbols = nonpublic_properties
dotnet_naming_rule.nonpublic_properties_pascal.style = pascal_case
dotnet_naming_rule.nonpublic_properties_pascal.severity = error

dotnet_naming_rule.locals_camel.symbols = locals
dotnet_naming_rule.locals_camel.style = camel_case
dotnet_naming_rule.locals_camel.severity = error

dotnet_naming_rule.parameters_camel.symbols = parameters
dotnet_naming_rule.parameters_camel.style = camel_case
dotnet_naming_rule.parameters_camel.severity = error
